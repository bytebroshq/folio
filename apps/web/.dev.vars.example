# Local development secrets for folio-web.
# Copy this to .dev.vars and fill in your GitHub credentials.
# Get these from the GitHub OAuth App and GitHub App you created.
#
#   cp .dev.vars.example .dev.vars
#

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
..."
